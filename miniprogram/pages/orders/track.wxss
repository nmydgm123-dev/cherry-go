.container {
  padding: 16px;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-section {
  margin-bottom: 16px;
}

.search-box {
  display: flex;
  gap: 12px;
}

.search-input {
  flex: 1;
  padding: 12px 16px;
  background: #ffffff;
  border-radius: 8px;
  font-size: 14px;
}

.search-btn {
  padding: 12px 24px;
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  color: #ffffff;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
}

.logistics-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
}

.logistics-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f5f5f5;
}

.order-no {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.status-tag {
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 12px;
}

.status-tag.status-pending {
  background: #fff3e0;
  color: #ff9800;
}

.status-tag.status-shipped {
  background: #e3f2fd;
  color: #2196f3;
}

.status-tag.status-delivered,
.status-tag.status-completed {
  background: #e8f5e9;
  color: #4caf50;
}

.receiver-info {
  margin-bottom: 16px;
}

.receiver-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.receiver-phone {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 4px;
}

.receiver-address {
  display: block;
  font-size: 13px;
  color: #999;
}

.tracking-section {
  padding-top: 16px;
  border-top: 1px solid #f5f5f5;
}

.tracking-list {
  position: relative;
  padding-left: 20px;
}

.tracking-item {
  position: relative;
  padding-bottom: 20px;
}

.tracking-item:last-child {
  padding-bottom: 0;
}

.tracking-dot {
  position: absolute;
  left: -20px;
  top: 4px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #ddd;
}

.tracking-dot.active {
  background: #E74C3C;
  box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.2);
}

.tracking-item::before {
  content: '';
  position: absolute;
  left: -16px;
  top: 14px;
  bottom: 0;
  width: 2px;
  background: #f0f0f0;
}

.tracking-item:last-child::before {
  display: none;
}

.tracking-content {
  display: flex;
  flex-direction: column;
}

.tracking-status {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.tracking-desc {
  font-size: 13px;
  color: #666;
  margin-bottom: 4px;
}

.tracking-time {
  font-size: 12px;
  color: #999;
}

.empty-tracking {
  padding: 40px 20px;
  text-align: center;
}

.empty-state {
  padding: 60px 20px;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}
