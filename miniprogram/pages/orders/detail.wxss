.container {
  padding: 16px;
  background: #f5f5f5;
  min-height: 100vh;
}

.status-header {
  padding: 32px 20px;
  border-radius: 16px;
  margin-bottom: 16px;
  text-align: center;
}

.status-header.status-pending {
  background: linear-gradient(135deg, #ff9800 0%, #f57c00 100%);
}

.status-header.status-shipped {
  background: linear-gradient(135deg, #2196f3 0%, #1976d2 100%);
}

.status-header.status-delivered,
.status-header.status-completed {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
}

.status-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 8px;
}

.status-text {
  font-size: 20px;
  font-weight: 600;
  color: #ffffff;
}

.info-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.card-title {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.info-label {
  font-size: 14px;
  color: #999;
}

.info-value {
  font-size: 14px;
  color: #333;
}

.address-info {
  line-height: 1.6;
}

.receiver {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.address {
  display: block;
  font-size: 14px;
  color: #666;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f5f5f5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-basic {
  flex: 1;
}

.product-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.product-spec {
  display: block;
  font-size: 13px;
  color: #999;
}

.product-price {
  text-align: right;
}

.product-price .price {
  font-size: 15px;
  font-weight: 600;
  color: #E74C3C;
}

.product-price .quantity {
  font-size: 14px;
  color: #999;
  margin: 0 4px;
}

.product-price .subtotal {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.logistics-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.company {
  font-size: 14px;
  color: #333;
}

.tracking-no {
  font-size: 14px;
  color: #E74C3C;
  font-weight: 600;
}

.photo-section {
  margin-top: 12px;
}

.photo-item {
  margin-bottom: 12px;
}

.photo-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.order-photo {
  width: 100%;
  height: 200px;
  border-radius: 8px;
  background: #f5f5f5;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.fee-row.total {
  padding-top: 12px;
  margin-top: 8px;
  border-top: 1px dashed #ddd;
}

.fee-label {
  font-size: 14px;
  color: #666;
}

.fee-value {
  font-size: 14px;
  color: #333;
}

.fee-value.discount {
  color: #4caf50;
}

.fee-row.total .fee-label {
  font-size: 15px;
  font-weight: 600;
  color: #333;
}

.fee-row.total .fee-value {
  font-size: 18px;
  font-weight: 600;
  color: #E74C3C;
}

.remarks {
  display: block;
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.writer-info {
  font-size: 14px;
  color: #666;
}
