.page { min-height: 100vh; background: #f5f5f5; }

.page-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; background: #fff; border-bottom: 1px solid #eee;
}
.back-btn { padding: 4px 8px; font-size: 15px; color: #e74c3c; }
.placeholder { visibility: hidden; }
.page-title { font-size: 16px; font-weight: 600; color: #333; }

.content { padding: 16px; }

.cal-card {
  background: #fff; border-radius: 14px; padding: 20px 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.cal-nav-row {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  margin-bottom: 16px;
}
.nav-btn {
  padding: 6px 12px; font-size: 16px; color: #999;
  background: #f5f5f5; border-radius: 6px;
}
.cal-title { font-size: 16px; font-weight: 600; color: #333; min-width: 140px; text-align: center; }

.cal-weekdays { display: flex; margin-bottom: 6px; }
.cal-weekday { flex: 1; text-align: center; font-size: 12px; color: #999; padding: 6px 0; }

.cal-grid { display: flex; flex-wrap: wrap; }
.cal-cell {
  width: 14.285%; aspect-ratio: 1;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  position: relative;
}
.cal-cell.empty { visibility: hidden; }
.cal-day { font-size: 14px; color: #333; }
.cal-cell.ship .cal-day { font-weight: 700; color: #e74c3c; }
.cal-icon { font-size: 16px; line-height: 1; margin-top: -2px; }

.cal-legend {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  margin-top: 16px; padding-top: 12px; border-top: 1px solid #f0f0f0;
}
.legend-icon { font-size: 14px; }
.legend-text { font-size: 12px; color: #999; }
