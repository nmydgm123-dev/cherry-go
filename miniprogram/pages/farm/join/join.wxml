<view class="page">
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">‹ 返回</view>
    <text class="page-title">加入果园</text>
    <view class="back-btn placeholder"></view>
  </view>

  <view class="content">
    <view class="card">
      <text class="field-label">邀请码</text>
      <input class="field-input code-input" placeholder="输入6位邀请码" value="{{inviteCode}}" bindinput="onCodeInput" maxlength="6" />
      <text class="field-hint">向果园主获取邀请码，输入后即可加入</text>
    </view>

    <view class="submit-btn {{!inviteCode.trim() ? 'disabled' : ''}}" bindtap="doJoin">
      <text wx:if="{{!joining}}">加入果园</text>
      <text wx:else>加入中...</text>
    </view>
  </view>
</view>
