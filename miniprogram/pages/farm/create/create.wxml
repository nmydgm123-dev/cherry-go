<view class="page">
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">‹ 返回</view>
    <text class="page-title">创建果园</text>
    <view class="back-btn placeholder"></view>
  </view>

  <view class="content">
    <view class="card">
      <text class="field-label">果园名称</text>
      <input class="field-input" placeholder="输入你的果园名称" value="{{farmName}}" bindinput="onNameInput" maxlength="20" />
      <text class="field-hint">创建后将自动生成6位邀请码，可分享给伙伴加入</text>
    </view>

    <view class="submit-btn {{!farmName.trim() || creating ? 'disabled' : ''}}" bindtap="doCreate">
      <text wx:if="{{!creating}}">创建果园</text>
      <text wx:else>创建中...</text>
    </view>
  </view>
</view>