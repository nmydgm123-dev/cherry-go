<view class="container">
  <view class="user-card">
    <view class="user-info">
      <image
        src="{{userInfo.avatar || 'https://api.dicebear.com/7.x/avataaars/svg?seed=cherrygo'}}"
        class="avatar"
      />
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
        <text wx:if="{{activeFarm}}" class="role-tag">当前果园：{{activeFarm.name}}</text>
      </view>
    </view>
    <view wx:if="{{!isLoggedIn}}" class="login-btn" bindtap="handleLogin">
      <text>点击登录</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-text">我的订单</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToTrack">
        <text class="menu-icon">🚚</text>
        <text class="menu-text">物流查询</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToFarmInfo">
        <text class="menu-icon">🏡</text>
        <text class="menu-text">果园信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToRevenue">
        <text class="menu-icon">📊</text>
        <text class="menu-text">营收统计</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToCalendar">
        <text class="menu-icon">🗓️</text>
        <text class="menu-text">发货日历</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{activeFarm && activeFarm.role === 'owner'}}" class="menu-group">
      <view class="menu-item" bindtap="goToProductConfig">
        <text class="menu-icon">📦</text>
        <text class="menu-text">商品配置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToShare">
        <text class="menu-icon">🔗</text>
        <text class="menu-text">邀请好友</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view wx:if="{{isLoggedIn}}" class="logout-section">
      <view class="logout-btn" bindtap="handleLogout">
        <text>退出登录</text>
      </view>
    </view>
  </view>
</view>
