.container {
  padding: 16px;
  background: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100px;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 16px;
  background: #ffffff;
  border-radius: 12px;
}

.product-left {
  margin-right: 12px;
}

.product-emoji {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
}

.product-middle {
  flex: 1;
}

.product-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.product-specs {
  font-size: 13px;
  color: #999;
}

.product-right {
  margin-left: 12px;
}

.action-buttons {
  display: flex;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  border-radius: 8px;
  background: #f5f5f5;
  font-size: 12px;
  color: #666;
}

.action-btn.delete {
  background: #ffebee;
  color: #E74C3C;
}

.empty-state {
  padding: 60px 20px;
  text-align: center;
}

.empty-icon {
  display: block;
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 14px;
  color: #999;
}

.add-btn {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(231, 76, 60, 0.4);
}

.add-icon {
  font-size: 28px;
  color: #ffffff;
  line-height: 1;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 90%;
  max-width: 400px;
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.modal-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: #999;
}

.modal-body {
  padding: 20px;
}

.preview-section {
  display: flex;
  justify-content: center;
  margin-bottom: 20px;
}

.preview-emoji {
  width: 80px;
  height: 80px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  padding: 12px 16px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  padding: 12px 16px;
  background: #f5f5f5;
  border-radius: 8px;
  font-size: 14px;
  box-sizing: border-box;
  min-height: 80px;
}

.form-row {
  display: flex;
  gap: 12px;
}

.form-half {
  flex: 1;
}

.picker {
  width: 100%;
  padding: 12px 16px;
  background: #f5f5f5;
  border-radius: 8px;
  text-align: center;
}

.picker-emoji {
  font-size: 24px;
}

.color-picker {
  display: flex;
  justify-content: center;
  align-items: center;
}

.color-dot {
  width: 28px;
  height: 28px;
  border-radius: 50%;
}

.size-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.size-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px;
  background: #f5f5f5;
  border-radius: 8px;
}

.size-name {
  flex: 2;
  padding: 8px 12px;
  background: #ffffff;
  border-radius: 6px;
  font-size: 14px;
}

.price-unit {
  font-size: 16px;
  font-weight: 600;
  color: #E74C3C;
}

.size-price {
  flex: 1;
  padding: 8px 12px;
  background: #ffffff;
  border-radius: 6px;
  font-size: 14px;
  text-align: right;
}

.remove-btn {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffebee;
  border-radius: 50%;
  color: #E74C3C;
  font-size: 18px;
  line-height: 1;
}

.add-size-btn {
  margin-top: 12px;
  padding: 12px;
  background: #e8f5e9;
  border-radius: 8px;
  text-align: center;
  color: #4caf50;
  font-size: 14px;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  padding: 12px;
  background: #f5f5f5;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  color: #666;
}

.confirm-btn {
  flex: 1;
  padding: 12px;
  background: linear-gradient(135deg, #E74C3C 0%, #C0392B 100%);
  border: none;
  border-radius: 8px;
  font-size: 14px;
  color: #ffffff;
}
