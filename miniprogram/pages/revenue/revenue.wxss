.page { min-height: 100vh; background: #f5f5f5; }

.page-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; background: #fff; border-bottom: 1px solid #eee;
}
.back-btn { padding: 4px 8px; font-size: 15px; color: #e74c3c; }
.placeholder { visibility: hidden; }
.page-title { font-size: 16px; font-weight: 600; color: #333; }

.content { padding: 16px; }

.card {
  background: #fff; border-radius: 14px; padding: 16px;
  margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.date-card {}
.card-title { display: block; font-size: 13px; color: #666; margin-bottom: 12px; }

.date-row { display: flex; align-items: center; gap: 8px; }
.date-picker {
  flex: 1; display: flex; align-items: center; gap: 4px;
  padding: 10px 12px; background: #f8f8f8; border-radius: 8px; border: 1px solid #eee;
}
.date-lbl { font-size: 12px; color: #999; }
.date-val { font-size: 14px; color: #333; font-weight: 500; }
.date-sep { font-size: 14px; color: #ccc; }

.query-btn {
  padding: 10px 20px; background: #e74c3c; color: #fff;
  border-radius: 8px; font-size: 14px; font-weight: 600; text-align: center;
}

.result-card {
  display: flex; align-items: center; justify-content: space-around;
  padding: 28px 16px;
}
.result-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.result-number { font-size: 24px; font-weight: 700; color: #e74c3c; }
.result-label { font-size: 12px; color: #999; }
.result-divider { width: 1px; height: 40px; background: #eee; }

.hint-card { text-align: center; padding: 30px; }
.hint-text { font-size: 14px; color: #ccc; }
